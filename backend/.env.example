# Server
NODE_ENV=development
PORT=4000

# Database (Postgres)
DATABASE_URL="postgresql://metron:metron@127.0.0.1:5434/metron?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth — generate strong values in production
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
COOKIE_SECRET="change-me-cookie"

# Access token = 15 min; Refresh token = 7 days. Change only if you know why.
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# CORS — frontend origin in dev
CORS_ORIGIN="http://localhost:5173"

# Exchange rate job
RATE_FETCH_INTERVAL_MS=900000
DOLARAPI_BASE="https://dolarapi.com/v1/dolares"
